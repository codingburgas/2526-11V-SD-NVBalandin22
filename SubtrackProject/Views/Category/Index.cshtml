@model List<SubtrackProject.DTOs.Category.CategoryListDto>
@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Categories</h1>
    <a asp-action="Create" class="btn btn-primary">+ New Category</a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table table-hover">
    <thead>
    <tr>
        <th>Color</th>
        <th>Name</th>
        <th>Description</th>
        <th>Subscriptions</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var c in Model)
    {
        <tr>
            <td><span class="badge" style="background-color:@c.Color">&nbsp;&nbsp;&nbsp;</span></td>
            <td>@c.Name</td>
            <td>@c.Description</td>
            <td>@c.SubscriptionCount</td>
            <td class="text-end">
                <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="d-inline"
                      onsubmit="return confirm('Delete this category?');">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>