@model SubtrackProject.DTOs.Subscription.SubscriptionListDto
@{
    ViewData["Title"] = "Subscription Details";
}

<h1 class="mb-4">@Model.Name</h1>

<div class="card" style="max-width: 500px">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-5">Category</dt>
            <dd class="col-7">
                <span class="badge" style="background-color:@Model.CategoryColor">@Model.CategoryName</span>
            </dd>

            <dt class="col-5">Price</dt>
            <dd class="col-7">@Model.Price.ToString("F2") €</dd>

            <dt class="col-5">Billing Cycle</dt>
            <dd class="col-7">@Model.BillingCycle</dd>

            <dt class="col-5">Next Payment</dt>
            <dd class="col-7">@Model.NextPaymentDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-5">Status</dt>
            <dd class="col-7">
                @if (Model.IsActive)
                {
                    <span class="badge text-bg-success">Active</span>
                }
                else
                {
                    <span class="badge text-bg-secondary">Paused</span>
                }
            </dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
</div>