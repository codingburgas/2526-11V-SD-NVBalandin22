@model List<SubtrackProject.DTOs.Subscription.SubscriptionListDto>
@{
    ViewData["Title"] = "My Subscriptions";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>My Subscriptions</h1>
    <a asp-action="Create" class="btn btn-primary">+ New Subscription</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">You don't have any subscriptions yet. Click "New Subscription" to add one.</div>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Cycle</th>
                <th>Next Payment</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var sub in Model)
        {
            <tr>
                <td>@sub.Name</td>
                <td>
                    <span class="badge" style="background-color:@sub.CategoryColor">@sub.CategoryName</span>
                </td>
                <td>@sub.Price.ToString("F2") €</td>
                <td>@sub.BillingCycle</td>
                <td>@sub.NextPaymentDate.ToString("yyyy-MM-dd")</td>
                <td>
                    @if (sub.IsActive)
                    {
                        <span class="badge text-bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge text-bg-secondary">Paused</span>
                    }
                </td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@sub.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                    <a asp-action="Edit" asp-route-id="@sub.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <form asp-action="Delete" asp-route-id="@sub.Id" method="post" class="d-inline"
                          onsubmit="return confirm('Delete this subscription?');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}